{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://mern-stack-ecommerce-project-nitt.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://mern-stack-ecommerce-project-nitt.onrender.com/uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
